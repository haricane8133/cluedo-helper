{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "outDir": "dist-tests",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false,
    "noEmit": false,
    "jsx": "react-jsx"
  },
  "include": ["src/web/lib/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "platforms"]
}
